# Server Configuration
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/election-crm
MONGODB_TEST_URI=mongodb://localhost:27017/election-crm-test

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-refresh-token-secret
JWT_REFRESH_EXPIRE=30d

# Deployment Model
DEPLOYMENT_MODE=saas
# Options: saas | dedicated

# Multi-tenant (for SaaS mode)
ENABLE_MULTI_TENANT=true

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Encryption (Required for messaging credentials)
ENCRYPTION_KEY=your-32-character-encryption-key-change-this-immediately

# Communication APIs (Optional)
WHATSAPP_API_KEY=
SMS_API_KEY=
SMS_SENDER_ID=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

# Logging
LOG_LEVEL=info
